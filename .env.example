# Nomor WhatsApp admin Warung Ratih yang akan menerima kiriman invoice pesanan.
# Gunakan kode negara di awal tanpa tanda +, spasi, atau strip.
VITE_WHATSAPP_NUMBER="6281234567890"

# URL produksi final untuk kebutuhan canonical, Open Graph, dan sitemap.
VITE_SITE_URL="https://warung-ratih.vercel.app"

# Aktifkan hanya bila admin panel lokal memang ingin ditampilkan.
VITE_ENABLE_ADMIN_PANEL="false"
